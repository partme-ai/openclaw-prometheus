{
  "id": "openclaw-prometheus",
  "name": "openclaw-prometheus",
  "version": "0.2.7",
  "description": "Prometheus metrics exporter for OpenClaw Gateway - based on real Gateway RPC methods (health, sessions.list, channels.status, usage, presence, cron, models, nodes, skills)",
  "main": "dist/index.js",
  "channels": [],
  "commands": [],
  "skills": [],
  "configSchema": {
    "type": "object",
    "properties": {
      "port": {
        "type": "number",
        "default": 9090,
        "description": "Dedicated metrics HTTP port (0 to use Gateway port)"
      },
      "path": {
        "type": "string",
        "default": "/metrics",
        "description": "Metrics endpoint path"
      },
      "collectIntervalMs": {
        "type": "number",
        "default": 15000,
        "description": "Metrics collection interval"
      },
      "includeRuntime": {
        "type": "boolean",
        "default": true,
        "description": "Include Node.js runtime metrics"
      },
      "scrapeAuth": {
        "type": "object",
        "description": "Optional Bearer token check on /metrics routes (token via openclaw-prometheus_BEARER_TOKEN recommended)",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "Require Authorization: Bearer on metrics HTTP routes"
          },
          "bearerToken": {
            "type": "string",
            "description": "Dev-only token; production should use env openclaw-prometheus_BEARER_TOKEN"
          }
        }
      }
    }
  },
  "uiHints": {
    "port": {
      "label": "Metrics Port",
      "placeholder": "9090"
    },
    "path": {
      "label": "Metrics Path",
      "placeholder": "/metrics"
    },
    "collectIntervalMs": {
      "label": "Collect Interval (ms)",
      "placeholder": "15000"
    },
    "includeRuntime": {
      "label": "Include Runtime Metrics",
      "type": "toggle"
    },
    "scrapeAuth.enabled": {
      "label": "Scrape auth (Bearer)",
      "type": "toggle"
    }
  },
  "capabilities": {
    "metricsExport": true
  }
}