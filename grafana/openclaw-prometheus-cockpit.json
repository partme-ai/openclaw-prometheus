{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for OpenClaw Prometheus plugin metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operations cockpit for @partme.ai/openclaw-prometheus: plugin health, Gateway workload (hooks), LLM tokens, model-auth probes, channels, and Node.js exporter process. Uses metrics actually emitted by the current plugin SDK path.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "code": { "language": "markdown", "showLineNumbers": false, "showMiniMap": false },
        "content": "# OpenClaw · Prometheus 运行驾驶舱\n\n本看板对齐 **当前插件实现** 所暴露的 `openclaw_*` 指标（Hooks、`api.runtime.*`、导出器自检、可选 `openclaw_nodejs_*`）。建议 **30s** 刷新；告警请优先使用 `openclaw_up`、`openclaw_ready`、`openclaw_model_auth_provider_probe_errors_total`、`openclaw_metrics_collect_errors_total`。",
        "mode": "markdown"
      },
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "id": 100,
      "panels": [],
      "title": "Health · 健康与元数据",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "插件进程已加载并成功注册指标路由。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "OK" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "openclaw_up", "legendFormat": "up", "refId": "A" }],
      "title": "Exporter loaded",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "是否观察到 gateway_start（就绪）。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "orange", "index": 0, "text": "NOT READY" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "READY" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 4 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "expr": "openclaw_ready", "legendFormat": "ready", "refId": "A" }],
      "title": "Gateway ready",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "decimals": 0, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 4 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "openclaw_plugin_uptime_seconds", "legendFormat": "uptime", "refId": "A" }],
      "title": "Plugin uptime",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "decimals": 3, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "id": 5,
      "options": { "colorMode": "none", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "openclaw_metrics_last_scrape_duration_seconds", "legendFormat": "scrape", "refId": "A" }],
      "title": "Last collection latency",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "decimals": 1, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "openclaw_runtime_snapshot_age_seconds", "legendFormat": "age", "refId": "A" }],
      "title": "Runtime snapshot age",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "name" },
      "targets": [{ "expr": "group by (version) (openclaw_exporter_build_info)", "legendFormat": "{{version}}", "refId": "A" }],
      "title": "Exporter version",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 101,
      "panels": [],
      "title": "Workload · Agent / 消息 / 工具",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 25, "gradientMode": "opacity", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (result) (rate(openclaw_agent_runs_total[5m]))", "legendFormat": "{{result}}", "refId": "A" }
      ],
      "title": "Agent runs / s（按 result）",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (channel) (rate(openclaw_messages_received_total[5m]))", "legendFormat": "in {{channel}}", "refId": "A" },
        { "expr": "sum by (channel) (rate(openclaw_messages_sent_total[5m]))", "legendFormat": "out {{channel}}", "refId": "B" }
      ],
      "title": "Messages / s（按 channel）",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "topk(12, sum by (tool) (rate(openclaw_tool_calls_total[5m])))", "legendFormat": "{{tool}}", "refId": "A" }
      ],
      "title": "Tool calls / s（Top 12）",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 13,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (kind) (openclaw_inflight_operations)", "legendFormat": "inflight {{kind}}", "refId": "A" }
      ],
      "title": "In-flight operations（估计值）",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "panels": [],
      "title": "LLM · Tokens",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 25, "gradientMode": "hue", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 27 },
      "id": 20,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (provider) (rate(openclaw_usage_tokens_input_total[5m]))", "legendFormat": "in {{provider}}", "refId": "A" },
        { "expr": "sum by (provider) (rate(openclaw_usage_tokens_output_total[5m]))", "legendFormat": "out {{provider}}", "refId": "B" },
        { "expr": "sum by (provider) (rate(openclaw_usage_tokens_cache_read_total[5m]))", "legendFormat": "cache read {{provider}}", "refId": "C" },
        { "expr": "sum by (provider) (rate(openclaw_usage_tokens_cache_write_total[5m]))", "legendFormat": "cache write {{provider}}", "refId": "D" }
      ],
      "title": "Token rate by provider（input / output / cache）",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 103,
      "panels": [],
      "title": "Plugin SDK · Hook 热力",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "showPoints": "never", "stacking": { "group": "A", "mode": "none" } },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 37 },
      "id": 30,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "topk(20, sum by (hook) (rate(openclaw_plugin_hook_invocations_total[5m])))", "legendFormat": "{{hook}}", "refId": "A" }
      ],
      "title": "Hook invocations / s（Top 20）",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "id": 104,
      "panels": [],
      "title": "Compaction · Subagent",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "id": 40,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (phase) (rate(openclaw_session_compaction_events_total[5m]))", "legendFormat": "{{phase}}", "refId": "A" },
        { "expr": "rate(openclaw_session_compaction_messages_compacted_total[5m])", "legendFormat": "messages compacted/s", "refId": "B" }
      ],
      "title": "Session compaction",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "id": 41,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (outcome) (rate(openclaw_subagent_ended_total[5m]))", "legendFormat": "{{outcome}}", "refId": "A" }
      ],
      "title": "Subagent ended / s",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 56 },
      "id": 105,
      "panels": [],
      "title": "Auth · Channels",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 57 },
      "id": 50,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (provider) (rate(openclaw_model_auth_provider_probe_errors_total[15m]))", "legendFormat": "probe err {{provider}}", "refId": "A" }
      ],
      "title": "Model-auth probe errors / s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 57 },
      "id": 51,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "openclaw_channel_last_inbound_age_seconds", "legendFormat": "inbound age {{channel}}/{{account}}", "refId": "A" },
        { "expr": "openclaw_channel_last_outbound_age_seconds", "legendFormat": "outbound age {{channel}}/{{account}}", "refId": "B" }
      ],
      "title": "Channel activity age（秒，按已观测 channel/account）",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 65 },
      "id": 106,
      "panels": [],
      "title": "Exporter process · Node.js（需 includeRuntime）",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "仅在 `includeRuntime: true`（默认）时存在。CPU 为进程累计时间，用 rate 表示近似 CPU 使用。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 66 },
      "id": 60,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "rate(openclaw_nodejs_process_cpu_user_seconds_total[2m])", "legendFormat": "CPU user (cores est.)", "refId": "A" },
        { "expr": "rate(openclaw_nodejs_process_cpu_system_seconds_total[2m])", "legendFormat": "CPU system (cores est.)", "refId": "B" },
        { "expr": "openclaw_nodejs_event_loop_lag_ms / 1000", "legendFormat": "event loop lag (s)", "refId": "C" }
      ],
      "title": "CPU rate & event-loop lag",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 18, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 66 },
      "id": 61,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "openclaw_nodejs_heap_used_bytes", "legendFormat": "heap used", "refId": "A" },
        { "expr": "openclaw_nodejs_rss_bytes", "legendFormat": "RSS", "refId": "B" },
        { "expr": "openclaw_nodejs_array_buffers_bytes", "legendFormat": "arrayBuffers", "refId": "C" }
      ],
      "title": "Memory",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 74 },
      "id": 107,
      "panels": [],
      "title": "Exporter self · HTTP / collectors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 12, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 75 },
      "id": 70,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "openclaw_metrics_collector_success", "legendFormat": "ok {{collector}}", "refId": "A" }
      ],
      "title": "Collector last success（1=ok）",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 75 },
      "id": 71,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by (method, route, status) (rate(openclaw_metrics_http_requests_total[5m]))", "legendFormat": "{{method}} {{route}} {{status}}", "refId": "A" }
      ],
      "title": "Exporter HTTP / s",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["openclaw", "prometheus", "cockpit", "operations"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
