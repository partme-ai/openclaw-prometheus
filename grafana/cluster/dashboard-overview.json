{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus" }],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.4.7" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
  ],
  "annotations": { "list": [{ "builtIn": 1, "datasource": { "type": "datasource", "uid": "grafana" }, "enable": true, "hide": true, "name": "Annotations & Alerts", "type": "dashboard" }] },
  "description": "OpenClaw 网关概览 — 100% 复刻 Control UI 概览页：网关状态、渠道会话、用量卡片（费用/Token/请求/消息/会话/技能/定时任务）、注意事项（认证过期/采集失败）、系统资源。中文面板标题。",
  "editable": true, "fiscalYearStartMonth": 0, "graphTooltip": 1, "id": null, "links": [],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "panels": [], "title": "网关状态（对齐 Gateway Access + Snapshot）", "type": "row" },
    { "id": 1, "type": "stat", "title": "实例数", "gridPos": { "h": 3, "w": 3, "x": 0, "y": 1 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"red"},{"color":"green","value":1}]} }, "overrides": [] },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"auto" },
      "targets": [{"expr":"count(openclaw_up)","refId":"A"}] },
    { "id": 2, "type": "stat", "title": "网关运行", "gridPos": { "h": 3, "w": 3, "x": 3, "y": 1 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "mappings": [{"options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}},"type":"value"}], "thresholds": {"mode":"absolute","steps":[{"color":"red"},{"color":"green","value":1}]} }, "overrides": [] },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_gateway_up","refId":"A"}] },
    { "id": 3, "type": "stat", "title": "插件运行", "gridPos": { "h": 3, "w": 3, "x": 6, "y": 1 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "mappings": [{"options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}},"type":"value"}], "thresholds": {"mode":"absolute","steps":[{"color":"red"},{"color":"green","value":1}]} }, "overrides": [] },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_up","refId":"A"}] },
    { "id": 4, "type": "stat", "title": "就绪", "gridPos": { "h": 3, "w": 3, "x": 9, "y": 1 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "mappings": [{"options":{"0":{"text":"NO","color":"red"},"1":{"text":"YES","color":"green"}},"type":"value"}], "thresholds": {"mode":"absolute","steps":[{"color":"red"},{"color":"green","value":1}]} }, "overrides": [] },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_ready","refId":"A"}] },
    { "id": 5, "type": "stat", "title": "运行时间", "gridPos": { "h": 3, "w": 3, "x": 12,"y": 1 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"s" }, "overrides": [] },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_plugin_uptime_seconds","refId":"A"}] },
    { "id": 6, "type": "stat", "title": "快照年龄", "gridPos": { "h": 3, "w": 3, "x": 15,"y": 1 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"},{"color":"orange","value":30},{"color":"red","value":60}]}, "unit":"s" }, "overrides": [] },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_runtime_snapshot_age_seconds","refId":"A"}] },
    { "id": 7, "type": "stat", "title": "采集耗时", "gridPos": { "h": 3, "w": 3, "x": 18,"y": 1 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"},{"color":"yellow","value":3},{"color":"red","value":5}]}, "unit":"s" }, "overrides": [] },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_metrics_last_scrape_duration_seconds","refId":"A"}] },
    { "id": 8, "type": "stat", "title": "采集失败", "gridPos": { "h": 3, "w": 3, "x": 21,"y": 1 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"},{"color":"red","value":1}]}, "unit":"short" }, "overrides": [] },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"sum(openclaw_metrics_collect_errors_total)","refId":"A"}] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }, "id": 101, "panels": [], "title": "渠道与会话", "type": "row" },
    { "id": 10, "type": "timeseries", "title": "会话按渠道", "gridPos": { "h": 7, "w": 8, "x": 0, "y": 5 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"palette-classic"}, "custom": {"fillOpacity":10,"lineWidth":1,"showPoints":"never"} }, "overrides": [] },
      "options": { "legend": { "calcs":["lastNotNull"],"displayMode":"table","placement":"bottom","showLegend":true}, "tooltip": {"mode":"multi","sort":"desc"} },
      "targets": [{"expr":"openclaw_session_by_channel","legendFormat":"{{channel}}","refId":"A"}] },
    { "id": 11, "type": "timeseries", "title": "渠道（总数/已链接）", "gridPos": { "h": 7, "w": 8, "x": 8, "y": 5 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"palette-classic"}, "custom": {"fillOpacity":10,"lineWidth":1,"showPoints":"never"} }, "overrides": [] },
      "options": { "legend": { "calcs":["lastNotNull"],"displayMode":"table","placement":"bottom","showLegend":true}, "tooltip": {"mode":"multi","sort":"desc"} },
      "targets": [{"expr":"openclaw_channel_total","legendFormat":"总数","refId":"A"},{"expr":"openclaw_channel_linked_total","legendFormat":"已链接","refId":"B"}] },
    { "id": 12, "type": "timeseries", "title": "会话数（总数/活跃30m）", "gridPos": { "h": 7, "w": 8, "x": 16,"y": 5 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"palette-classic"}, "custom": {"fillOpacity":10,"lineWidth":1,"showPoints":"never"} }, "overrides": [] },
      "options": { "legend": { "calcs":["lastNotNull"],"displayMode":"table","placement":"bottom","showLegend":true}, "tooltip": {"mode":"multi","sort":"desc"} },
      "targets": [{"expr":"openclaw_session_total","legendFormat":"总数","refId":"A"},{"expr":"openclaw_session_active_recent","legendFormat":"活跃","refId":"B"}] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 }, "id": 102, "panels": [], "title": "用量概览（对齐 Overview Cards：费用·会话·技能·定时·认证）", "type": "row" },
    { "id": 20, "type": "stat", "title": "费用 / USD", "gridPos": { "h": 3, "w": 4, "x": 0, "y": 13 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"currencyUSD","decimals":2 } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"sum(openclaw_usage_cost_usd_total)","refId":"A"}] },
    { "id": 21, "type": "stat", "title": "Token 总量", "gridPos": { "h": 3, "w": 4, "x": 4, "y": 13 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"sum(openclaw_usage_model_tokens_total)","refId":"A"}] },
    { "id": 22, "type": "stat", "title": "请求数", "gridPos": { "h": 3, "w": 4, "x": 8, "y": 13 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"sum(openclaw_usage_model_requests_total)","refId":"A"}] },
    { "id": 23, "type": "stat", "title": "消息数", "gridPos": { "h": 3, "w": 4, "x": 12,"y": 13 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"sum(openclaw_usage_messages_total)","refId":"A"}] },
    { "id": 24, "type": "stat", "title": "会话数", "gridPos": { "h": 3, "w": 4, "x": 16,"y": 13 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_session_total","refId":"A"}] },
    { "id": 25, "type": "stat", "title": "技能数", "gridPos": { "h": 3, "w": 4, "x": 20,"y": 13 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_skill_total","refId":"A"}] },
    { "id": 26, "type": "stat", "title": "定时任务", "gridPos": { "h": 3, "w": 4, "x": 0, "y": 16 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_cron_total","refId":"A"}] },
    { "id": 27, "type": "stat", "title": "Cron 运行中", "gridPos": { "h": 3, "w": 4, "x": 4, "y": 16 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_cron_running","refId":"A"}] },
    { "id": 28, "type": "stat", "title": "认证即将过期", "gridPos": { "h": 3, "w": 4, "x": 8, "y": 16 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"},{"color":"orange","value":1}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_model_auth_providers_expiring_total","refId":"A"}] },
    { "id": 29, "type": "stat", "title": "认证已过期", "gridPos": { "h": 3, "w": 4, "x": 12,"y": 16 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"},{"color":"red","value":1}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_model_auth_providers_expired_total","refId":"A"}] },
    { "id": 30, "type": "stat", "title": "活跃 Presence", "gridPos": { "h": 3, "w": 4, "x": 16,"y": 16 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_presence_total","refId":"A"}] },
    { "id": 31, "type": "stat", "title": "指标基数", "gridPos": { "h": 3, "w": 4, "x": 20,"y": 16 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"},{"color":"yellow","value":50000},{"color":"red","value":100000}]}, "unit":"short" } },
      "options": { "colorMode":"background", "reduceOptions": {"calcs":["lastNotNull"],"values":false}, "textMode":"value" },
      "targets": [{"expr":"openclaw_metrics_series_total","refId":"A"}] },
    { "id": 32, "type": "timeseries", "title": "每日成本趋势 / USD（7天）", "gridPos": { "h": 8, "w": 24,"x": 0, "y": 19 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"palette-classic"}, "custom": {"fillOpacity":10,"lineWidth":1,"showPoints":"never"}, "unit":"currencyUSD","decimals":2 }, "overrides": [] },
      "options": { "legend": { "calcs":["lastNotNull"],"displayMode":"table","placement":"bottom","showLegend":true}, "tooltip": {"mode":"multi","sort":"desc"} },
      "targets": [{"expr":"openclaw_usage_model_daily_cost_usd_total","legendFormat":"{{model}} {{date}}","refId":"A"}] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }, "id": 103, "panels": [], "title": "注意事项（对齐 Attention Panel）", "type": "row" },
    { "id": 40, "type": "table", "title": "模型认证状态", "gridPos": { "h": 5, "w": 8, "x": 0, "y": 28 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "模型 API Key 状态。missing/error 为严重，需要重新认证。",
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "custom": {"align":"auto"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"},{"color":"red","value":80}]} }, "overrides": [{"matcher":{"id":"byName","options":"状态"},"properties":[{"id":"mappings","value":[{"options":{"ok":{"text":"✅ 正常","color":"green"},"missing":{"text":"❌ 缺失","color":"red"},"error":{"text":"❌ 错误","color":"red"}},"type":"value"}]}]}] },
      "options": { "footer": {"show":false}, "showHeader":true },
      "targets": [{"expr":"openclaw_model_auth_provider_status","format":"table","instant":true,"refId":"A"}],
      "transformations": [{"id":"organize","options":{"excludeByName":{"Time":true,"instance":true,"job":true,"__name__":true},"renameByName":{"provider":"提供商","status":"状态"}}}] },
    { "id": 41, "type": "table", "title": "采集器状态", "gridPos": { "h": 5, "w": 8, "x": 8, "y": 28 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "各采集器健康状态。FAIL 时需要检查 Gateway RPC 连接。",
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "custom": {"align":"auto"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"},{"color":"red","value":80}]} }, "overrides": [{"matcher":{"id":"byName","options":"Value"},"properties":[{"id":"mappings","value":[{"options":{"0":{"text":"❌ FAIL","color":"red"},"1":{"text":"✅ OK","color":"green"}},"type":"value"}]}]}] },
      "options": { "footer": {"show":false}, "showHeader":true },
      "targets": [{"expr":"openclaw_metrics_collector_success","format":"table","instant":true,"refId":"A"}],
      "transformations": [{"id":"organize","options":{"excludeByName":{"Time":true,"instance":true,"job":true,"__name__":true},"renameByName":{"collector":"采集器"}}}] },
    { "id": 42, "type": "table", "title": "热门模型（成本 Top 10）", "gridPos": { "h": 5, "w": 8, "x": 16,"y": 28 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "custom": {"align":"auto"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]} }, "overrides": [{"matcher":{"id":"byName","options":"费用"},"properties":[{"id":"unit","value":"currencyUSD"},{"id":"decimals","value":2}]}] },
      "options": { "footer": {"show":false}, "showHeader":true },
      "targets": [{"expr":"topk(10, openclaw_usage_model_cost_usd_total)","format":"table","instant":true,"refId":"A"}],
      "transformations": [{"id":"organize","options":{"excludeByName":{"Time":true,"instance":true,"job":true,"__name__":true},"renameByName":{"model":"模型","Value":"费用","provider":"提供商"}}}] },
    { "id": 43, "type": "table", "title": "Top Agents（Token 排行）", "gridPos": { "h": 5, "w": 8, "x": 0, "y": 33 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "custom": {"align":"auto"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"}]} }, "overrides": [{"matcher":{"id":"byName","options":"Token"},"properties":[{"id":"unit","value":"short"}]}] },
      "options": { "footer": {"show":false}, "showHeader":true },
      "targets": [{"expr":"topk(25, openclaw_usage_agent_tokens_total)","format":"table","instant":true,"refId":"A"}],
      "transformations": [{"id":"organize","options":{"excludeByName":{"Time":true,"instance":true,"job":true,"__name__":true},"renameByName":{"agent":"Agent","Value":"Token"}}}] },
    { "id": 44, "type": "timeseries", "title": "渠道链接详情", "gridPos": { "h": 5, "w": 8, "x": 8, "y": 33 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "按 channel_id 展开的链接状态。1=已链接，0=未链接。",
      "fieldConfig": { "defaults": { "color": {"mode":"palette-classic"}, "custom": {"fillOpacity":15,"lineWidth":1,"showPoints":"never"}, "thresholds": {"mode":"absolute","steps":[{"color":"red"},{"color":"yellow","value":0.5},{"color":"green","value":1}]}, "unit":"short","min":0,"max":1 }, "overrides": [] },
      "options": { "legend": { "calcs":["lastNotNull"],"displayMode":"table","placement":"bottom","showLegend":true}, "tooltip": {"mode":"multi","sort":"desc"} },
      "targets": [{"expr":"openclaw_channel_linked","legendFormat":"{{channel_id}}({{channel_label}})","refId":"A"}] },
    { "id": 45, "type": "table", "title": "Cron 作业状态", "gridPos": { "h": 5, "w": 8, "x": 16,"y": 33 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"thresholds"}, "custom": {"align":"auto"}, "thresholds": {"mode":"absolute","steps":[{"color":"green"},{"color":"red","value":80}]} }, "overrides": [{"matcher":{"id":"byName","options":"结果"},"properties":[{"id":"mappings","value":[{"options":{"0":{"text":"❌ 失败","color":"red"},"1":{"text":"✅ 成功","color":"green"}},"type":"value"}]}]}] },
      "options": { "footer": {"show":false}, "showHeader":true },
      "targets": [{"expr":"openclaw_cron_last_result","format":"table","instant":true,"refId":"A"}],
      "transformations": [{"id":"organize","options":{"excludeByName":{"Time":true,"instance":true,"job":true,"__name__":true},"renameByName":{"job":"作业","Value":"结果"}}}] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 }, "id": 104, "panels": [], "title": "系统资源", "type": "row" },
    { "id": 50, "type": "timeseries", "title": "Node.js 内存 (Heap / RSS)", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 39 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"palette-classic"}, "custom": {"fillOpacity":10,"lineWidth":1,"showPoints":"never"}, "unit":"decbytes" }, "overrides": [] },
      "options": { "legend": { "calcs":["mean","max"],"displayMode":"table","placement":"bottom","showLegend":true}, "tooltip": {"mode":"multi","sort":"desc"} },
      "targets": [{"expr":"openclaw_nodejs_heap_used_bytes","legendFormat":"Heap","refId":"A"},{"expr":"openclaw_nodejs_rss_bytes","legendFormat":"RSS","refId":"B"}] },
    { "id": 51, "type": "timeseries", "title": "事件循环延迟 / ms", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 39 }, "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": {"mode":"palette-classic"}, "custom": {"fillOpacity":10,"lineWidth":1,"showPoints":"never"}, "unit":"ms" }, "overrides": [] },
      "options": { "legend": { "calcs":["max"],"displayMode":"table","placement":"bottom","showLegend":true}, "tooltip": {"mode":"multi","sort":"desc"} },
      "targets": [{"expr":"openclaw_nodejs_event_loop_lag_ms","legendFormat":"延迟","refId":"A"}] },
